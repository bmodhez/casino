datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

enum Role {
  USER
  ADMIN
}

enum GameType {
  MINES
  DICE
  COINFLIP
  PLINKO
}

model User {
  id               String             @id @default(uuid())
  username         String             @unique
  email            String             @unique
  passwordHash     String?            // Nullable for OAuth accounts
  image            String?            // Avatar URL or path
  role             Role               @default(USER)
  coins            Float              @default(1000.0)
  xp               Int                @default(0)
  level            Int                @default(1)
  banned           Boolean            @default(false)
  lastDailyClaimed DateTime?
  lastWheelSpin    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  gameHistory      GameHistory[]
  gameSessions     GameSession[]
  seeds            ProvablyFairSeed[]
  sessions         Session[]
  accounts         Account[]
  dailyStreaks     DailyStreak[]
}

model DailyStreak {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Int      // Day number (1-7)
  weekStart DateTime // Start of the week this claim belongs to
  claimedAt DateTime @default(now())

  @@unique([userId, weekStart, day])
  @@index([userId, weekStart])
}

model ProvablyFairSeed {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverSeed     String   // Plain Server Seed (hidden from user until rotated)
  serverSeedHash String   // Public SHA-256 hash of serverSeed
  clientSeed     String   // Customizable client seed
  nonce          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model GameHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType   GameType
  betAmount  Float
  payout     Float
  multiplier Float
  win        Boolean
  mineCount  Int?
  serverSeed String
  clientSeed String
  nonce      Int
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([gameType])
  @@index([createdAt])
}

model GameSession {
  id            String   @id @default(uuid())
  userId        String
  gameType      GameType
  mineCount     Int?     // null for non-mines games
  betAmount     Float
  minePositions Json?    // only for mines
  gemsRevealed  Int      @default(0)
  details       Json?    // game-specific data (crashPoint, dice target, etc.)
  status        String   @default("ACTIVE")
  serverSeed    String
  clientSeed    String
  nonce         Int
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@index([expiresAt])
}

// NextAuth models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
